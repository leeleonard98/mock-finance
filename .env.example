# App
APP_ENV=dev

# Database (matches docker-compose.yml defaults)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/app
TEST_DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/app_test

# OpenAI — leave blank to disable real LLM calls (tests use a mock seam)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Upload safety caps (defends /transactions/upload from large-file DoS)
MAX_UPLOAD_BYTES=5242880
MAX_UPLOAD_ROWS=10000
